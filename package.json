{
  "name": "partner-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "cleanup:storage:dry": "npx tsx scripts/cleanup-partner-document-duplicates.ts",
    "cleanup:storage:delete": "powershell -NoProfile -Command \"$env:CONFIRM_DELETE='true'; npx tsx scripts/cleanup-partner-document-duplicates.ts\"",
    "cleanup:storage:nonessential:dry": "npx tsx scripts/cleanup-storage-nonessential.ts",
    "cleanup:storage:nonessential:delete": "powershell -NoProfile -Command \"$env:CONFIRM_DELETE='true'; npx tsx scripts/cleanup-storage-nonessential.ts\"",
    "cleanup:contacts:invalid-names:dry": "npx tsx scripts/cleanup-invalid-contact-names.ts",
    "cleanup:contacts:invalid-names:delete": "powershell -NoProfile -Command \"$env:CONFIRM_DELETE='true'; npx tsx scripts/cleanup-invalid-contact-names.ts\"",
    "merge:contacts:dry": "npx tsx scripts/merge-duplicate-contacts.ts",
    "merge:contacts:run": "powershell -NoProfile -Command \"$env:CONFIRM_MERGE='true'; npx tsx scripts/merge-duplicate-contacts.ts\"",
    "normalize:phones:dry": "npx tsx scripts/normalize-contact-phones.ts",
    "normalize:phones:run": "powershell -NoProfile -Command \"$env:CONFIRM_NORMALIZE='true'; npx tsx scripts/normalize-contact-phones.ts\"",
    "fixtures:partner-contracts": "node scripts/generate-partner-contract-fixtures.js",
    "test:partner-application": "npx tsx scripts/test-partner-application.ts",
    "test:official-stats-exclude": "npx tsx scripts/test-official-stats-exclude.ts",
    "test:auth-redirect": "npx tsx scripts/test-auth-redirect.ts"
  },
  "dependencies": {
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "jszip": "^3.10.1",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "xlsx": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "^10.5.0",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "latest"
  }
}
